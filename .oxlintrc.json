{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "typescript", "import", "unicorn", "promise", "vitest"],
  "env": {
    "browser": true,
    "node": true,
    "vitest": true
  },
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "warn"
  },
  "ignorePatterns": [
    ".agents/**",
    ".ssealed/**",
    ".cache/**",
    "coverage/**",
    "dist/**",
    "node_modules/**"
  ],
  "options": {
    "denyWarnings": true,
    "reportUnusedDisableDirectives": "error",
    "typeAware": true,
    "typeCheck": false
  },
  "rules": {
    "eqeqeq": "error",
    "no-debugger": "error",
    "typescript/await-thenable": "error",
    "typescript/no-floating-promises": "error",
    "typescript/no-misused-promises": "error"
  },
  "overrides": [
    {
      "files": ["src/main.ts"],
      "rules": {
        "import/no-unassigned-import": "off"
      }
    },
    {
      "files": ["src/presentation/**/*.ts"],
      "rules": {
        "unicorn/no-array-fill-with-reference-type": "off"
      }
    }
  ]
}
